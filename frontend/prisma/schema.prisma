generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model KnowledgeAsset {
  id        Int      @id @default(autoincrement())
  title     String
  category  String
  summary   String
  source    String
  tags      String
  status    String
  createdAt DateTime @default(now())
}
